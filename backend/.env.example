MONGO_URI=mongodb://localhost:27017
PORT=8000
GOOGLE_MAPS_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=ap-south-1
CAMPUS_FOOD_S3_BUCKET=
CAMPUS_FOOD_S3_KEY=campus_food.json
BEDROCK_ENABLED=false
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0

# Meta WhatsApp Cloud API credentials
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_TOKEN=

# Twilio WhatsApp API credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Frontend base URL (CloudFront domain in production, e.g. https://d3g6cg7q9hn7hi.cloudfront.net)
FRONTEND_BASE_URL=http://localhost:5173

# Account Aggregator sandbox integration
# Keep disabled unless you are explicitly testing AA sandbox flows.
AA_SANDBOX_ENABLED=false
# local = PocketBuddy's built-in dummy-data sandbox lifecycle.
# Provider sandboxes require FIU credentials and provider-specific onboarding.
AA_SANDBOX_PROVIDER=local
AA_SANDBOX_BASE_URL=
AA_CLIENT_ID=
AA_CLIENT_SECRET=
AA_FIU_ID=
AA_CALLBACK_SECRET=
